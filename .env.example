# NDNP Open OCR Configuration
# Copy to .env and edit: cp .env.example .env

# AWS
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-2

# Environment (suffix for all resource names)
ENVIRONMENT=development-deployment

# S3/ECR
S3_OUTPUT_BUCKET_PREFIX=ndnp-open-ocr-output-bucket
BATCH_IMAGE_TAG=opensource1.2.0
ECR_REPO_PREFIX=ndnp-open-ocr-container-repo
